known
*.swp
*.zwc
.DS_Store
.netrc

# Editor state
.vim/.netrwhist
.vim/files/
.vim/spell/*.spl
bin/nvim

# Stray nvim artifact (literal filename "!")
\!

# Tmux runtime
.tmux/plugins/*
.tmux/resurrect/

# Sundry app caches / runtime state
.config/configstore
.config/.isolated-storage/
.config/bpytop/
.config/go/
.config/karabiner/automatic_backups/
.config/thefuck/__pycache__/
.config/thefuck/settings.pyc
.config/uv/
.config/wireshark/
.fonts/.uuid

# Credentials / auth tokens — NEVER commit
.claude/
.config/cursor/
.config/gcloud/
.config/github-copilot/
.config/heroku
.config/hub
.config/rclone/
# SSH: defensive — block private keys, per-host configs, and runtime state.
# .ssh/config IS tracked; everything else here is per-host / secret.
.ssh/id_*
.ssh/*.key
.ssh/*.pem
.ssh/config.local
.ssh/known_hosts*
.ssh/authorized_keys*
.ssh/sockets/
.ssh/environment-*

# Old / unused app configs
.config/gqrx
.config/gtk-2.0
.config/inkscape
.config/rtv
.config/xm1
.xmonad/xmonad-arm-linux
