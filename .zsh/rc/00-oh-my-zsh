# Path to your oh-my-zsh configuration.
ZSH=$HOME/.oh-my-zsh

# Customizations go here
ZSH_CUSTOM=$HOME/.oh-my-zsh-custom

# Prompt is powerlevel10k (loaded via ZSH_CUSTOM/themes/powerlevel10k and
# configured from ~/.p10k.zsh below). Leave ZSH_THEME empty so oh-my-zsh
# doesn't load a no-op fallback theme that just gets overridden.
ZSH_THEME="powerlevel10k/powerlevel10k"

# Set to this to use case-sensitive completion
# CASE_SENSITIVE="true"

# Comment this out to disable weekly auto-update checks
# DISABLE_AUTO_UPDATE="true"

# Uncomment following line if you want to disable colors in ls
# DISABLE_LS_COLORS="true"

# Uncomment following line if you want to disable autosetting terminal title.
# DISABLE_AUTO_TITLE="true"

# Uncomment following line if you want red dots to be displayed while waiting for completion
COMPLETION_WAITING_DOTS="true"

# Disable security checks to speed startup
ZSH_DISABLE_COMPFIX="true"

# tmux stuff
#ZSH_TMUX_AUTOSTART="true"

# For Jira
JIRA_URL="https://amperity.atlassian.net/"

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block, everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi


# Which plugins would you like to load? (plugins can be found in ~/.oh-my-zsh/plugins/*)
# Custom plugins may be added to ~/.oh-my-zsh/custom/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Note: brew and macos are loaded via ZSH_MACOS_PLUGINS from .zsh/os/apple when on macOS

# Conditionally load language plugins if installed
ZSH_LANG_PLUGINS=""
command -v python3 >/dev/null && ZSH_LANG_PLUGINS="$ZSH_LANG_PLUGINS python"
command -v ruby >/dev/null && ZSH_LANG_PLUGINS="$ZSH_LANG_PLUGINS ruby"

plugins=(${=ZSH_MACOS_PLUGINS} ${=ZSH_LANG_PLUGINS} autojump tmux fzf debian docker git gh history safe-paste sudo zsh-syntax-highlighting zsh-autosuggestions)

source $ZSH/oh-my-zsh.sh
# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
