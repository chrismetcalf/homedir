#!/usr/bin/env python3
"""
Ping Monitor - Network connectivity monitoring daemon
"""

import sys
from pathlib import Path

# Add the parent directory to Python path (resolve symlinks)
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from pingmon.monitor import main
from pingmon.config import Config

if __name__ == "__main__":
    # Handle --init-config flag
    if "--init-config" in sys.argv:
        Config.create_default()
        sys.exit(0)

    main()
