#!/usr/bin/env bash

set -euo pipefail

INSTALL_DIR="$HOME/bin"
INSTALL_PATH="$INSTALL_DIR/nvim"

# Detect OS
OS=$(uname -s)
ARCH=$(uname -m)

case "$OS" in
  Darwin)
    # macOS
    case "$ARCH" in
      x86_64)
        FILENAME="nvim-macos-x86_64.tar.gz"
        ;;
      arm64)
        FILENAME="nvim-macos-arm64.tar.gz"
        ;;
      *)
        echo "❌ Unsupported macOS architecture: $ARCH"
        exit 1
        ;;
    esac
    ;;
  Linux)
    # Linux (asset names changed in v0.10.4: nvim-linux64 → nvim-linux-x86_64)
    case "$ARCH" in
      x86_64)
        FILENAME="nvim-linux-x86_64.tar.gz"
        ;;
      aarch64 | arm64)
        FILENAME="nvim-linux-arm64.tar.gz"
        ;;
      *)
        echo "❌ Unsupported Linux architecture: $ARCH"
        exit 1
        ;;
    esac
    ;;
  *)
    echo "❌ Unsupported OS: $OS"
    exit 1
    ;;
esac

echo "🔍 Fetching latest Neovim release info..."
API_URL="https://api.github.com/repos/neovim/neovim/releases/latest"
RELEASE_JSON=$(curl -fsSL "$API_URL")

# Use sed instead of grep -P for macOS compatibility
TAG_NAME=$(echo "$RELEASE_JSON" | sed -n 's/.*"tag_name": "\([^"]*\)".*/\1/p' | head -n1)
DOWNLOAD_URL="https://github.com/neovim/neovim/releases/download/$TAG_NAME/$FILENAME"

echo "🔎 Found latest release: $TAG_NAME"
echo "🌐 Download URL: $DOWNLOAD_URL"

echo "📦 Downloading $FILENAME..."
curl -fLo "$FILENAME" "$DOWNLOAD_URL"

echo "📂 Creating $INSTALL_DIR if it doesn't exist..."
mkdir -p "$INSTALL_DIR"

echo "📦 Extracting tarball..."
tar xzf "$FILENAME"

# Find the nvim binary in the extracted directory
EXTRACTED_DIR=$(tar tzf "$FILENAME" | head -1 | cut -f1 -d"/")

echo "🚚 Moving to $INSTALL_PATH"
mv "$EXTRACTED_DIR/bin/nvim" "$INSTALL_PATH"

echo "🧹 Cleaning up..."
rm -rf "$EXTRACTED_DIR" "$FILENAME"

echo "✅ Neovim $TAG_NAME installed to $INSTALL_PATH"

if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
  echo "⚠️ $INSTALL_DIR is not in your PATH."
  echo "👉 Add this to your ~/.bashrc or ~/.zshrc:"
  echo "   export PATH=\"\$HOME/bin:\$PATH\""
else
  echo "🚀 Verifying:"
  "$INSTALL_PATH" --version
fi

